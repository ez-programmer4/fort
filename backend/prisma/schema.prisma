generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Phase 1: Auth, Users & Roles ─────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  passwordHash String
  roleId       Int
  role         Role     @relation(fields: [roleId], references: [id])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movements        StockMovement[]
  purchaseOrders   PurchaseOrder[]
  goodsReceipts    GoodsReceipt[]
  expensePurchases ExpensePurchase[]
  dispenseOrders   DispenseOrder[]
  payments         Payment[]
  stockTransfers   StockTransfer[]
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id     Int              @id @default(autoincrement())
  key    String           @unique
  label  String
  module String
  roles  RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ── Phase 2: Locations & Suppliers ───────────────────────────

model Location {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  type          String // Retail | Warehouse | Dispensary | Other
  address       String
  contactPerson String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  movements      StockMovement[]
  stocks         Stock[]
  purchaseOrders PurchaseOrder[]
  goodsReceipts  GoodsReceipt[]
  dispenseOrders DispenseOrder[]
  transfersOut   StockTransfer[] @relation("TransferFrom")
  transfersIn    StockTransfer[] @relation("TransferTo")
}

model Supplier {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  tin          String?
  phone        String?
  email        String?
  address      String?
  bankAccounts Json      @default("[]") // [{ bankName, accountNumber }]
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  products         Product[]
  batches          Batch[]
  purchaseOrders   PurchaseOrder[]
  goodsReceipts    GoodsReceipt[]
  expensePurchases ExpensePurchase[]
}

// ── Phase 3: Products, Lookups, Bin Card foundations ─────────

model Lookup {
  id       Int    @id @default(autoincrement())
  category String // doseForm | route | doseUnit | unit
  value    String

  @@unique([category, value])
}

model Product {
  id               Int             @id @default(autoincrement())
  code             String          @unique
  type             String // Medication | Equipment | Cosmetics
  pharmClass       String
  genericName      String
  brandName        String?
  description      String?
  strength         String?
  doseUnit         String?
  route            String?
  doseForm         String?
  orderUnit        String?
  dispenseUnit     String?
  conversionFactor Float           @default(1)
  countryOfOrigin  String?
  manufacturer     String?
  supplierId       Int?
  supplier         Supplier?       @relation(fields: [supplierId], references: [id])
  unitPrice        Decimal         @default(0) @db.Decimal(12, 2)
  // Per-product alert thresholds, in this product's dispense unit
  minStock         Int? // low-stock alert when total at a location falls below this
  maxStock         Int? // over-stock alert when total at a location exceeds this
  expiryAlertDays  Int? // days before expiry to start alerting (null = default 90)
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  batches          Batch[]
  movements        StockMovement[]
  poItems          PurchaseOrderItem[]
  grvItems         GRVItem[]
  dispenseItems    DispenseItem[]
  transferItems    StockTransferItem[]
}

model Batch {
  id         Int             @id @default(autoincrement())
  productId  Int
  product    Product         @relation(fields: [productId], references: [id])
  batchNo    String
  expiryDate DateTime?
  supplierId Int?
  supplier   Supplier?       @relation(fields: [supplierId], references: [id])
  unitCost   Decimal?        @db.Decimal(12, 2)
  createdAt  DateTime        @default(now())
  movements     StockMovement[]
  stocks        Stock[]
  grvItems      GRVItem[]
  dispenseItems DispenseItem[]
  transferItems StockTransferItem[]

  @@unique([productId, batchNo])
}

// ── Phase 5: Procurement (Purchase Orders, GRV, expenses) ────

model PurchaseOrder {
  id          Int                 @id @default(autoincrement())
  poNumber    String              @unique
  supplierId  Int?
  supplier    Supplier?           @relation(fields: [supplierId], references: [id])
  locationId  Int
  location    Location            @relation(fields: [locationId], references: [id])
  status      String              @default("OPEN") // OPEN | RECEIVED | CANCELLED
  notes       String?
  createdById Int
  createdBy   User                @relation(fields: [createdById], references: [id])
  createdAt   DateTime            @default(now())
  items       PurchaseOrderItem[]
  receipts    GoodsReceipt[]
}

model PurchaseOrderItem {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       Int
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  unitCost        Decimal       @db.Decimal(12, 2)
  batchNo         String?
  expiryDate      DateTime?
}

model GoodsReceipt {
  id                Int            @id @default(autoincrement())
  grvNumber         String         @unique
  purchaseOrderId   Int?
  purchaseOrder     PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  supplierId        Int?
  supplier          Supplier?      @relation(fields: [supplierId], references: [id])
  locationId        Int
  location          Location       @relation(fields: [locationId], references: [id])
  subtotal          Decimal        @db.Decimal(14, 2)
  withholdingType   String         @default("NONE") // NONE | GOODS | SERVICES
  withholdingRate   Decimal        @default(0) @db.Decimal(5, 2)
  withholdingAmount Decimal        @default(0) @db.Decimal(14, 2)
  netPayable        Decimal        @db.Decimal(14, 2)
  notes             String?
  receivedById      Int
  receivedBy        User           @relation(fields: [receivedById], references: [id])
  createdAt         DateTime       @default(now())
  items             GRVItem[]
}

model GRVItem {
  id             Int          @id @default(autoincrement())
  goodsReceiptId Int
  goodsReceipt   GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  productId      Int
  product        Product      @relation(fields: [productId], references: [id])
  batchId        Int
  batch          Batch        @relation(fields: [batchId], references: [id])
  quantity       Int
  unitCost       Decimal      @db.Decimal(12, 2)
}

// Non-sale purchases: office supplies, services, etc. (no inventory impact)
model ExpensePurchase {
  id                Int       @id @default(autoincrement())
  description       String
  category          String?
  supplierId        Int?
  supplier          Supplier? @relation(fields: [supplierId], references: [id])
  amount            Decimal   @db.Decimal(14, 2)
  withholdingType   String    @default("NONE") // NONE | GOODS | SERVICES
  withholdingRate   Decimal   @default(0) @db.Decimal(5, 2)
  withholdingAmount Decimal   @default(0) @db.Decimal(14, 2)
  netPayable        Decimal   @db.Decimal(14, 2)
  purchasedAt       DateTime  @default(now())
  notes             String?
  createdById       Int
  createdBy         User      @relation(fields: [createdById], references: [id])
}

// ── Phase 6: Sales & Dispensing ──────────────────────────────

model Customer {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String?
  email        String?
  bankAccounts Json     @default("[]") // [{ bankName, accountNumber }]
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  dispenseOrders DispenseOrder[]

  @@index([name])
}

model DispenseOrder {
  id                Int            @id @default(autoincrement())
  dspNumber         String         @unique
  locationId        Int
  location          Location       @relation(fields: [locationId], references: [id])
  customerId        Int?
  customer          Customer?      @relation(fields: [customerId], references: [id])
  paymentType       String         @default("CASH") // CASH | CREDIT
  subtotal          Decimal        @db.Decimal(14, 2)
  withholdingType   String         @default("NONE") // NONE | GOODS | SERVICES
  withholdingRate   Decimal        @default(0) @db.Decimal(5, 2)
  withholdingAmount Decimal        @default(0) @db.Decimal(14, 2)
  total             Decimal        @db.Decimal(14, 2) // subtotal − withholding
  notes             String?
  dispensedById     Int
  dispensedBy       User           @relation(fields: [dispensedById], references: [id])
  createdAt         DateTime       @default(now())
  items             DispenseItem[]
  attachments       Attachment[]
  payments          Payment[]
}

model DispenseItem {
  id              Int           @id @default(autoincrement())
  dispenseOrderId Int
  dispenseOrder   DispenseOrder @relation(fields: [dispenseOrderId], references: [id], onDelete: Cascade)
  productId       Int
  product         Product       @relation(fields: [productId], references: [id])
  batchId         Int
  batch           Batch         @relation(fields: [batchId], references: [id])
  quantity        Int
  listPrice       Decimal       @db.Decimal(12, 2) // product price at time of sale
  unitPrice       Decimal       @db.Decimal(12, 2) // actual (possibly adjusted) sale price
}

// ── Phase 7: Wallet / Finance ────────────────────────────────

model Payment {
  id              Int           @id @default(autoincrement())
  dispenseOrderId Int
  dispenseOrder   DispenseOrder @relation(fields: [dispenseOrderId], references: [id])
  amount          Decimal       @db.Decimal(14, 2)
  method          String        @default("CASH") // CASH | BANK_TRANSFER | CHEQUE | MOBILE
  reference       String?
  notes           String?
  receivedById    Int
  receivedBy      User          @relation(fields: [receivedById], references: [id])
  createdAt       DateTime      @default(now())
}

model Attachment {
  id              Int           @id @default(autoincrement())
  dispenseOrderId Int
  dispenseOrder   DispenseOrder @relation(fields: [dispenseOrderId], references: [id], onDelete: Cascade)
  storedName      String
  originalName    String
  mimeType        String
  size            Int
  createdAt       DateTime      @default(now())
}

// ── Phase 10: system settings ────────────────────────────────

model Setting {
  key   String @id
  value Json
}

// ── Phase 4: current stock per batch × location ──────────────

model Stock {
  id         Int      @id @default(autoincrement())
  batchId    Int
  batch      Batch    @relation(fields: [batchId], references: [id])
  locationId Int
  location   Location @relation(fields: [locationId], references: [id])
  quantity   Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([batchId, locationId])
}

model StockMovement {
  id            Int      @id @default(autoincrement())
  productId     Int
  product       Product  @relation(fields: [productId], references: [id])
  batchId       Int?
  batch         Batch?   @relation(fields: [batchId], references: [id])
  locationId    Int
  location      Location @relation(fields: [locationId], references: [id])
  type          String // GRV | DISPENSE | ADJUST_INCREASE | ADJUST_DECREASE | TRANSFER_IN | TRANSFER_OUT
  direction     String // IN | OUT
  quantity      Int
  reason        String?
  remark        String?
  performedById Int
  performedBy   User     @relation(fields: [performedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([productId, locationId, createdAt])
}

// ── Phase A10: inter-location stock transfers ────────────────

model StockTransfer {
  id             Int                 @id @default(autoincrement())
  transferNumber String              @unique
  fromLocationId Int
  fromLocation   Location            @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocationId   Int
  toLocation     Location            @relation("TransferTo", fields: [toLocationId], references: [id])
  notes          String?
  performedById  Int
  performedBy    User                @relation(fields: [performedById], references: [id])
  createdAt      DateTime            @default(now())
  items          StockTransferItem[]
}

model StockTransferItem {
  id              Int           @id @default(autoincrement())
  stockTransferId Int
  stockTransfer   StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  productId       Int
  product         Product       @relation(fields: [productId], references: [id])
  batchId         Int
  batch           Batch         @relation(fields: [batchId], references: [id])
  quantity        Int
}
